# ChronoCarta environment variables
# Copy this file to .env.local and fill in real values. Never commit .env.local.

# --- Runtime (server + client) ---

# Supabase project URL (e.g. https://abcdefghijklmnop.supabase.co)
SUPABASE_URL=

# Supabase anon key. Safe to expose to the browser; RLS enforces access.
# The NEXT_PUBLIC_ prefix tells Next.js to bundle it for client components.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase service role key. Bypasses RLS. SERVER ONLY — never expose to the client.
# Used exclusively in lib/supabase/game-client.ts.
SUPABASE_SERVICE_ROLE_KEY=

# Secret used to sign and verify the game-state JWT. Generate with: openssl rand -hex 32
GAME_STATE_SECRET=

# Number of maps per game session.
ROUNDS_PER_GAME=10

# --- Test (integration suite, separate Supabase project) ---

SUPABASE_TEST_URL=
SUPABASE_TEST_ANON_KEY=
SUPABASE_TEST_SERVICE_ROLE_KEY=
