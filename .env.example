# ChronoCarta environment variables
# Copy this file to .env.local and fill in real values. Never commit .env.local.

# --- Runtime (server + client) ---

# Supabase project URL (e.g. https://abcdefghijklmnop.supabase.co)
SUPABASE_URL=

# Supabase publishable key (sb_publishable_*). Safe to expose to the browser;
# RLS enforces access. The NEXT_PUBLIC_ prefix tells Next.js to bundle it for
# client components.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Supabase secret key (sb_secret_*). Bypasses RLS. SERVER ONLY — never expose
# to the client. Used exclusively in lib/supabase/game-client.ts.
SUPABASE_SECRET_KEY=

# Secret used to sign and verify the game-state JWT.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
GAME_STATE_SECRET=

# Number of maps per game session.
ROUNDS_PER_GAME=10

# --- Test (integration suite) ---
# Pre-launch the test environment is the TEST branch of the main Supabase
# project. Same Supabase project, isolated database.

SUPABASE_TEST_URL=
SUPABASE_TEST_PUBLISHABLE_KEY=
SUPABASE_TEST_SECRET_KEY=

# Passwords for the two seeded auth users on the TEST branch. Used by the
# integration tests in tests/integration/ to call signInWithPassword and
# obtain real curator / admin sessions for RLS exercises.
TEST_CURATOR_PASSWORD=
TEST_ADMIN_PASSWORD=
